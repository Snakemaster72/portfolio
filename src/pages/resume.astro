---
import Base from "../layouts/Base.astro";
---

<Base title="Résumé — Swarnav Mukherjee">
  <div class="resume-header">
    <h1>Résumé</h1>
    <a href="/resume.pdf" download class="dl-btn">Download PDF ↓</a>
  </div>

  <div class="frame-wrap">
    <iframe
      src="/resume.pdf"
      title="Swarnav Mukherjee — Résumé"
      class="resume-frame"
    ></iframe>
  </div>
</Base>

<style>
  .resume-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .resume-header h1 {
    margin: 0;
  }

  .dl-btn {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid rgba(74, 122, 90, 0.35);
    border-radius: 4px;
    padding: 0.3rem 0.75rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dl-btn:hover {
    background: rgba(74, 122, 90, 0.07);
    text-decoration: none;
  }

  /* Break out of the 65ch body constraint so the PDF has room to breathe */
  .frame-wrap {
    width: 100vw;
    position: relative;
    left: 50%;
    margin-left: -50vw;
    padding: 0 1.25rem;
    box-sizing: border-box;
  }

  .resume-frame {
    display: block;
    width: 100%;
    height: calc(100vh - 10rem);
    border: 1px solid var(--border);
    border-radius: 4px;
    background: #fff;
  }
</style>
