---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const allNotes = await getCollection("notes");
  const topicSet = new Set(allNotes.flatMap((n) => n.data.topics ?? []));

  return [...topicSet].map((topic) => ({
    params: { topic },
    props: {
      topic,
      notes: allNotes
        .filter((n) => (n.data.topics ?? []).includes(topic))
        .sort((a, b) => b.data.tended.getTime() - a.data.tended.getTime()),
    },
  }));
}

const { topic, notes } = Astro.props;

function formatDate(d: Date) {
  return d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}
---

<Base title={`#${topic} — Digital Garden`}>
  <h1>#{topic}</h1>
  <p class="meta">{notes.length} note{notes.length === 1 ? "" : "s"}</p>

  <ul class="note-list">
    {notes.map((note) => (
      <li class="note-item">
        <a href={`/notes/${note.id}`} class="note-link">{note.data.title}</a>
        <span class="note-meta">
          <span class={`growth-label ${note.data.growth}`}>{note.data.growth}</span>
          &middot; {formatDate(note.data.tended)}
        </span>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 {
    margin-bottom: 0.25rem;
  }

  .note-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
  }

  .note-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .note-item:last-child {
    border-bottom: none;
  }

  .note-link {
    color: var(--text);
    text-decoration: none;
    flex: 1;
  }

  .note-link:hover {
    color: var(--accent);
  }

  .note-meta {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
  }
</style>
