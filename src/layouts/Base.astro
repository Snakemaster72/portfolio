---
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/">Home</a>
        <a href="/projects">Projects</a>
        <a href="/garden">Garden</a>
        <a href="/about">About</a>
        <a href="/resume" class="nav-resume">Résumé</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --bg: #faf9f7;
    --text: #2c2a26;
    --muted: #7a7570;
    --border: #e8e4de;
    --accent: #4a7a5a;
    --seedling-color: #b8860b;
    --budding-color: #4a7a4a;
    --evergreen-color: #1d5c32;
  }

  html { background: var(--bg); color: var(--text); }

  body {
    font-family: Georgia, 'Palatino Linotype', serif;
    line-height: 1.75;
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1.25rem 4rem;
  }

  a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  a:hover { text-decoration-thickness: 2px; }

  h1 { font-size: 1.75rem; margin: 0 0 0.5rem; line-height: 1.25; }
  h2 { font-size: 1.2rem; margin: 2rem 0 0.6rem; line-height: 1.3; }

  p { margin: 1em 0; }

  /* ── Site header ── */
  .site-header {
    padding: 1.25rem 0;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .site-header nav {
    display: flex;
    gap: 1.5rem;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .site-header nav a {
    color: var(--muted);
    text-decoration: none;
  }

  .site-header nav a:hover { color: var(--accent); }

  /* ── Shared note metadata ── */
  .meta {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
    color: var(--muted);
    font-size: 0.875rem;
    font-family: ui-sans-serif, system-ui, sans-serif;
  }

  .topics {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .topic {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    color: var(--accent);
    background: rgba(74, 122, 90, 0.1);
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    text-decoration: none;
    border: 1px solid rgba(74, 122, 90, 0.2);
  }

  .topic:hover {
    background: rgba(74, 122, 90, 0.18);
    text-decoration: none;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.75rem 0;
  }

  /* ── Growth stage indicators ── */
  .stage-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .stage-dot.seedling  { background: var(--seedling-color); }
  .stage-dot.budding   { background: var(--budding-color); }
  .stage-dot.evergreen { background: var(--evergreen-color); }

  .growth-label {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .growth-label.seedling  { color: var(--seedling-color); }
  .growth-label.budding   { color: var(--budding-color); }
  .growth-label.evergreen { color: var(--evergreen-color); }
</style>
